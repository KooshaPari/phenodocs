{
  "name": "phenodocs",
  "version": "0.1.0",
  "private": true,
  "description": "VitePress Federation Hub - Aggregate documentation from multiple projects",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "vitepress dev",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "lint": "markdownlint docs/**/*.md",
    "lint:ts": "oxlint .vitepress --config oxlint.json",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "check": "bun run lint:ts && bun run typecheck && uv run python scripts/check_docs_links.py",
    "check-links": "uv run python scripts/check_docs_links.py"
  },
  "dependencies": {
    "vitepress": "^1.5.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.47.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "documentation",
    "vitepress",
    "federation",
    "hub",
    "multi-project"
  ],
  "author": "Kush Team",
  "license": "MIT"
}
